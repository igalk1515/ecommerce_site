{
  "name": "@store/api",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "prisma:migrate": "node scripts/with-root-env.mjs prisma migrate dev",
    "prisma:seed": "node scripts/with-root-env.mjs tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "@prisma/client": "^5.20.0",
    "@store/shared": "workspace:*",
    "argon2": "^0.41.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.0.0",
    "stripe": "^17.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.20.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
