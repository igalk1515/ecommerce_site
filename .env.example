# ==========================
# Shared / Runtime
# ==========================
# PostgreSQL connection string used by Prisma and the API.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sports_store

# JWT signing secret for admin authentication cookies.
# Use a long random value in production.
JWT_SECRET=change-me-to-a-long-random-secret

# Comma-separated list of allowed origins for API CORS (used by Fastify CORS plugin).
# In dev this should include the local Next.js app.
WEB_ORIGIN=http://localhost:3000

# ==========================
# API (apps/api)
# ==========================
# API port.
PORT=4000

# Optional: Stripe secret key for creating checkout sessions.
# If empty, checkout falls back to internal success flow for local development.
STRIPE_SECRET_KEY=

# Public web URL used by API when constructing Stripe success/cancel URLs.
STRIPE_WEB_URL=http://localhost:3000

# Optional SMTP settings (future-ready). Current MVP logs emails to console if unset.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# ==========================
# Web (apps/web)
# ==========================
# Base API URL consumed by the Next.js frontend.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Canonical site URL used for metadata/sitemap/robots.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX).
# Script is injected only if this value is provided.
NEXT_PUBLIC_GA4_ID=
